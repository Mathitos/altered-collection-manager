generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Cards ───────────────────────────────────────────────────────────────────

model Card {
  id               String   @id @default(uuid())
  collection       String   // BTG, SKY, CORE...
  collectionNumber Int      // 39, 81...
  rarity           String   // C, R, F, E
  name             String
  faction          String   // AX, BR, LY, MU, OR, YZ
  type             String   // Character, Spell, Permanent, Token, Hero
  mainCost         Int?
  recallCost       Int?
  forestPower      Int?
  mountainPower    Int?
  oceanPower       Int?
  abilityText      String?
  supportText      String?
  flavorText       String?
  translations     Json?    // {"pt": {"name": "...", "abilityText": "...", "supportText": "...", "flavorText": "..."}}
  variants         Json?    // [{variantId, language, imageUrl, artist, isCollectorArt}]

  deckCards        DeckCard[]
  userCollections  UserCollection[]
  decksAsHero      Deck[]   @relation("DeckHero")

  @@unique([collection, collectionNumber, faction, rarity])
  @@map("cards")
}

model UniqueCard {
  id               String   @id @default(uuid())
  collection       String
  collectionNumber Int
  uniqueId         Int      // 1447 — individual instance identifier
  rarity           String   @default("U")
  faction          String
  type             String   // Always "Character" for unique cards
  mainCost         Int?
  recallCost       Int?
  forestPower      Int?
  mountainPower    Int?
  oceanPower       Int?
  name             String
  abilityText      String?
  supportText      String?
  flavorText       String?
  translations     Json?
  variants         Json?

  deckCards        DeckCard[]
  userCollections  UserCollection[]

  @@unique([collection, collectionNumber, uniqueId])
  @@map("unique_cards")
}

// ─── Auth (NextAuth.js) ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts        Account[]
  sessions        Session[]
  decks           Deck[]
  userCollections UserCollection[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Decks ────────────────────────────────────────────────────────────────────

model Deck {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean  @default(false)
  shareToken  String   @unique @default(cuid())
  heroCardId  String   // FK → Card (Hero type)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  heroCard Card       @relation("DeckHero", fields: [heroCardId], references: [id])
  cards    DeckCard[]

  @@map("decks")
}

model DeckCard {
  id           String  @id @default(uuid())
  deckId       String
  cardId       String? // FK → Card (mutually exclusive with uniqueCardId)
  uniqueCardId String? // FK → UniqueCard
  variantId    String? // Reference to variantId inside card's variants JSONB
  quantity     Int     @default(1) // 1–3 for common/rare; always 1 for unique

  deck       Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card       Card?       @relation(fields: [cardId], references: [id])
  uniqueCard UniqueCard? @relation(fields: [uniqueCardId], references: [id])

  @@map("deck_cards")
}

// ─── User Collection ──────────────────────────────────────────────────────────

model UserCollection {
  id           String  @id @default(uuid())
  userId       String
  cardId       String? // FK → Card (mutually exclusive with uniqueCardId)
  uniqueCardId String? // FK → UniqueCard
  quantity     Int     @default(1)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  card       Card?       @relation(fields: [cardId], references: [id])
  uniqueCard UniqueCard? @relation(fields: [uniqueCardId], references: [id])

  @@map("user_collection")
}
